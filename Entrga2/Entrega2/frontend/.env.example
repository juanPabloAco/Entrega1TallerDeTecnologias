# Address of the deployed Multisig contract (filled in by scripts/deploy.ts)
VITE_MULTISIG_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: WalletConnect Cloud project ID (https://cloud.walletconnect.com).
# Without it, RainbowKit still works with injected wallets (MetaMask, Rabby, etc).
VITE_WC_PROJECT_ID=
