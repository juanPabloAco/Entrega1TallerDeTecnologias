# RPC endpoint for Sepolia (Infura, Alchemy, or public endpoint)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# Private key of the deployer account (must have Sepolia ETH)
# IMPORTANT: Never commit a real private key. This is the DEPLOYER only, not a signer of the multisig.
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Etherscan API key for contract verification (https://etherscan.io/myapikey)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
